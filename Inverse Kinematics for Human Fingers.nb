Cell[BoxData[
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"mindist", "\[LessEqual]", "dist"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"qprev", "=", "q"}], ";", "\[IndentingNewLine]", 
     RowBox[{"JTran", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "JI", "]"}], "/.", 
