      RowBox[{"70", ",", "18"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p", "=", 
     RowBox[{"(", GridBox[{
        {"x"},
        {"y"}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "inital", " ", "guesses", " ", 
     "for", " ", "\[Theta]M", " ", "and", " ", 
     RowBox[{"\[Theta]P", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
