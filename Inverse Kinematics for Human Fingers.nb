Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "target", " ", "locations", " ", 
    "for", " ", "x", " ", "and", " ", "y", " ", "of", " ", "the", " ", 
