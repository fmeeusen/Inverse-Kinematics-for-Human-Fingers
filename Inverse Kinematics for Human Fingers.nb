Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "In", " ", "this", " ", "example", " ", "we", " ", "simply", " ", "use", 
    " ", "the", " ", "transpose", " ", "of", " ", "the", " ", "Jacobian", " ",
     "rather", " ", "than", " ", "the", " ", "inverse", " ", "and", " ", 
    "see", " ", "what", " ", "the", " ", "difference", " ", "in", " ", 
    "performance", " ", 
    RowBox[{"is", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "target", " ", "locations", " ", 
    "for", " ", "x", " ", "and", " ", "y", " ", "of", " ", "the", " ", 
    "index", " ", 
    RowBox[{"finger", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{"60", ",", "18"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p", "=", 
     RowBox[{"(", GridBox[{
        {"x"},
        {"y"}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "inital", " ", "guesses", " ", 
     "for", " ", "\[Theta]M", " ", "and", " ", 
     RowBox[{"\[Theta]P", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Theta]M0", ",", "\[Theta]P0"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{"0.1", ",", "0.1"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"q", "=", 
     RowBox[{"(", GridBox[{
        {"\[Theta]M0"},
        {"\[Theta]P0"}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "Jacobian", " ", "matrix", " ", 
     "for", " ", "the", " ", "index", " ", "finger", " ", "and", " ", "its", 
     " ", "inverse", " ", "evaluated", " ", "at", " ", "the", " ", "values", 
     " ", "for", " ", "\[Theta]M", " ", "and", " ", "\[Theta]P", " ", "for", 
     " ", "the", " ", "ith", " ", 
     RowBox[{"iteration", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JI", "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"D", "[", 
          RowBox[{"DIPIx", ",", "\[Theta]MI"}], "]"}], 
         RowBox[{"D", "[", 
          RowBox[{"DIPIx", ",", "\[Theta]PI"}], "]"}]},
        {
         RowBox[{"D", "[", 
          RowBox[{"DIPIy", ",", "\[Theta]MI"}], "]"}], 
         RowBox[{"D", "[", 
          RowBox[{"DIPIy", ",", "\[Theta]PI"}], "]"}]}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"intresults", "=", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"\[Theta]M0", ",", "\[Theta]P0"}], "}"}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"This", " ", "defines", " ", "the", " ", "distance", " ", 
      RowBox[{"criteria", ".", " ", "i", ".", "e", "."}]}], ",", " ", 
     RowBox[{
     "when", " ", "is", " ", "the", " ", "iterative", " ", "solver", " ", 
      "close", " ", 
      RowBox[{"enough", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mindist", "=", "0.05"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "dist", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dist", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"notmoved", "=", "0"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8940879283656983`*^9, 3.894088008177889*^9}, {
  3.8940882628087425`*^9, 3.8940882647382793`*^9}, {3.8940895956102324`*^9, 
