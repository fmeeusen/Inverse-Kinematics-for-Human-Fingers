    RowBox[{
     RowBox[{
     "This", " ", "defines", " ", "the", " ", "Jacobian", " ", "matrix", " ", 
      "for", " ", "the", " ", "index", " ", "finger", " ", "and", " ", "its", 
      " ", "inverse", " ", "evaluated", " ", "at", " ", "the", " ", "values", 
      " ", "for", " ", "\[Theta]M"}], ",", " ", 
