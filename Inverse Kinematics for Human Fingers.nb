Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"mindist", "\[LessEqual]", "dist"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"JIinv", "=", 
       RowBox[{
        RowBox[{"PseudoInverse", "[", "JI", "]"}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Theta]MI", "\[Rule]", 
           RowBox[{"q", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
          RowBox[{"\[Theta]PI", "\[Rule]", " ", 
           RowBox[{"q", "[", 
            RowBox[{"[", 
             RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ",", 
          RowBox[{"\[Theta]DI", "\[Rule]", " ", 
           RowBox[{"q", "[", 
            RowBox[{"[", 
             RowBox[{"3", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "This", " ", "defines", " ", "the", " ", "current", " ", "location", 
         " ", "of", " ", "the", " ", "end"}], "-", 
        RowBox[{
        "effector", " ", "of", " ", "the", " ", "finger", " ", "considering", 
         " ", "that", " ", "the", " ", "angles", " ", "are", " ", "updated", 
         " ", "to", " ", "the", " ", "ith", " ", "itteration"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"pc", "=", 
       RowBox[{"(", GridBox[{
          {
           RowBox[{"DIPIx", "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Theta]MI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"\[Theta]PI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"\[Theta]DI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"3", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]},
          {
           RowBox[{"DIPIy", "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Theta]MI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"\[Theta]PI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ",", 
              RowBox[{"\[Theta]DI", "\[Rule]", " ", 
               RowBox[{"q", "[", 
                RowBox[{"[", 
                 RowBox[{"3", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]}
         }], ")"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "This", " ", "defines", " ", "the", " ", "difference", " ", "between", 
        " ", "the", " ", "current", " ", "location", " ", "and", " ", "the", 
        " ", 
        RowBox[{"target", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"\[Delta]p", "=", 
       RowBox[{"p", "-", "pc"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"q", "=", 
       RowBox[{"q", "+", 
        RowBox[{
         RowBox[{"(", "JIinv", ")"}], ".", "\[Delta]p"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dist", "=", 
       SqrtBox[
        RowBox[{
         SuperscriptBox[
          RowBox[{"\[Delta]p", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"\[Delta]p", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "1"}], "]"}], "]"}], "2"]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"This", " ", "clips"}], ",", " ", 
        RowBox[{"the", " ", 
         RowBox[{"value", ".", " ", "Meaning"}], " ", "that", " ", "if", " ", 
         "it", " ", "goes", " ", "over", " ", "the", " ", "boundary", " ", 
         "value"}], ",", " ", 
        RowBox[{
        "it", " ", "will", " ", "reset", " ", "to", " ", "the", " ", 
         "bounadry", " ", 
         RowBox[{"value", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Note", " ", "that", " ", "we", " ", "can", " ", "also", " ", 
         "choose", " ", "to", " ", "do", " ", "this", " ", "at", " ", "the", 
         " ", "end"}], ",", " ", 
        RowBox[{
        "but", " ", "this", " ", "will", " ", "give", " ", "a", " ", 
         "heuristic", " ", "to", " ", "increase", " ", "the", " ", 
         "probability", " ", "that", " ", "we", " ", "do", " ", "not", " ", 
         "end", " ", "up", " ", "in", " ", "a", " ", "solution", " ", "that", 
         " ", "is", " ", "not", " ", "possible", " ", "for", " ", "the", " ", 
         RowBox[{"fingers", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
      " ", 
      RowBox[{
       RowBox[{"q", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"Clip", "[", 
        RowBox[{
         RowBox[{"q", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
           FractionBox[
            RowBox[{"-", "\[Pi]"}], "3"], ",", 
           FractionBox["\[Pi]", "3"]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"q", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"Clip", "[", 
        RowBox[{
         RowBox[{"q", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
           FractionBox[
            RowBox[{
             RowBox[{"-", "2"}], "\[Pi]"}], "3"], ",", 
           RowBox[{"-", "0.1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"q", "[", 
        RowBox[{"[", 
         RowBox[{"3", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"Clip", "[", 
        RowBox[{
         RowBox[{"q", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{
           FractionBox[
            RowBox[{
             RowBox[{"-", "2"}], "\[Pi]"}], "3"], ",", 
           RowBox[{"-", "0.1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"intresults", ",", 
        RowBox[{"Flatten", "[", "q", "]"}]}], "]"}]}]}], "]"}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
