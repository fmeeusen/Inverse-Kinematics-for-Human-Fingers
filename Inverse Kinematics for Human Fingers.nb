Cell[BoxData[
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"mindist", "\[LessEqual]", "dist"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"qprev", "=", "q"}], ";", "\[IndentingNewLine]", 
     RowBox[{"JIinv", "=", 
      RowBox[{
       RowBox[{"Inverse", "[", "JI", "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Theta]MI", "\[Rule]", 
          RowBox[{"q", "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
         RowBox[{"\[Theta]PI", "\[Rule]", " ", 
          RowBox[{"q", "[", 
           RowBox[{"[", 
            RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "This", " ", "defines", " ", "the", " ", "current", " ", "location", 
        " ", "of", " ", "the", " ", "end"}], "-", 
       RowBox[{
       "effector", " ", "of", " ", "the", " ", "finger", " ", "considering", 
        " ", "that", " ", "the", " ", "angles", " ", "are", " ", "updated", 
        " ", "to", " ", "the", " ", "ith", " ", "itteration"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"pc", "=", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"DIPIx", "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[Theta]MI", "\[Rule]", " ", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
             RowBox[{"\[Theta]PI", "\[Rule]", " ", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]},
         {
          RowBox[{"DIPIy", "/.", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[Theta]MI", "\[Rule]", " ", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ",", 
             RowBox[{"\[Theta]PI", "\[Rule]", " ", 
              RowBox[{"q", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], "}"}]}]}
        }], ")"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "defines", " ", "the", " ", "difference", " ", "between", 
       " ", "the", " ", "current", " ", "location", " ", "and", " ", "the", 
       " ", 
       RowBox[{"target", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"\[Delta]p", "=", 
      RowBox[{"p", "-", "pc"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"q", "=", 
      RowBox[{"q", "+", 
       RowBox[{
        RowBox[{"(", "JIinv", ")"}], ".", "\[Delta]p"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "defines", " ", "the", " ", "difference", " ", "between", 
       " ", "the", " ", "obtained", " ", "solution", " ", "and", " ", "the", 
       " ", 
       RowBox[{"target", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"dist", "=", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Delta]p", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], "2"], "+", 
        SuperscriptBox[
         RowBox[{"\[Delta]p", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}], "2"]}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{"This", " ", "clips"}], ",", " ", 
       RowBox[{"the", " ", 
        RowBox[{"value", ".", " ", "Meaning"}], " ", "that", " ", "if", " ", 
        "it", " ", "goes", " ", "over", " ", "the", " ", "boundary", " ", 
        "value"}], ",", " ", 
       RowBox[{
       "it", " ", "will", " ", "reset", " ", "to", " ", "the", " ", 
        "bounadry", " ", 
        RowBox[{"value", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "Note", " ", "that", " ", "we", " ", "can", " ", "also", " ", "choose",
         " ", "to", " ", "do", " ", "this", " ", "at", " ", "the", " ", 
        "end"}], ",", " ", 
       RowBox[{
       "but", " ", "this", " ", "will", " ", "give", " ", "a", " ", 
        "heuristic", " ", "to", " ", "increase", " ", "the", " ", 
        "probability", " ", "that", " ", "we", " ", "do", " ", "not", " ", 
        "end", " ", "up", " ", "in", " ", "a", " ", "solution", " ", "that", 
        " ", "is", " ", "not", " ", "possible", " ", "for", " ", "the", " ", 
        RowBox[{"fingers", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", " ", 
     RowBox[{
      RowBox[{"q", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", 
      RowBox[{"Clip", "[", 
       RowBox[{
        RowBox[{"q", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          FractionBox[
           RowBox[{"-", "\[Pi]"}], "3"], ",", 
          FractionBox["\[Pi]", "3"]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"q", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}], "=", 
      RowBox[{"Clip", "[", 
       RowBox[{
        RowBox[{"q", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          FractionBox[
           RowBox[{
            RowBox[{"-", "2"}], "\[Pi]"}], "3"], ",", 
          RowBox[{"-", "0.1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Delta]p", "=", 
      RowBox[{"p", "-", "pc"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"intresults", ",", 
       RowBox[{"Flatten", "[", "q", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Delta]q", "=", 
      RowBox[{"q", "-", "qprev"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"diff", "=", 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"\[Delta]q", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], "2"], "+", 
        SuperscriptBox[
         RowBox[{"\[Delta]q", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}], "2"]}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"diff", "<", "mindist"}], ",", " ", 
       RowBox[{"notmoved", "++"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"notmoved", "\[GreaterEqual]", "3"}], ",", " ", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"q", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], "+=", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["\[Pi]", "4"]}], ",", 
            FractionBox["\[Pi]", "4"]}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"q", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}], "+=", 
         RowBox[{"RandomReal", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", 
             FractionBox["\[Pi]", "4"]}], ",", 
            FractionBox["\[Pi]", "4"]}], "}"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"notmoved", "=", "0"}], ";"}]}], "]"}], ";", " ", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "There", " ", "is", " ", "a", " ", "chance", " ", "that", " ", "the", 
        " ", "iterative", " ", "solver", " ", "becomes", " ", "stuck", " ", 
        RowBox[{"(", 
         RowBox[{
         "see", " ", "what", " ", "happens", " ", "if", " ", "we", " ", 
          "take", " ", 
          RowBox[{"(", 
           RowBox[{"50", ",", "18"}], ")"}], " ", "as", " ", "desired", " ", 
          "input", " ", 
          RowBox[{"positions", "."}]}], ")"}], " ", "To", " ", "prevent", " ",
         "this", " ", "from", " ", "happening", " ", "we", " ", "impose", " ",
         "a", " ", "new", " ", 
        RowBox[{"criteria", ":", " ", 
         RowBox[{
         "If", " ", "the", " ", "distance", " ", "between", " ", "previous", 
          " ", "and", " ", "current", " ", "iteration", " ", "is", " ", 
          "less", " ", "then", " ", "0.05", " ", "for", " ", "three", " ", 
          "iterations"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{
        "random", " ", "motion", " ", "will", " ", "take", " ", "place"}], 
        ";", " ", 
        RowBox[{"I", ".", "e", "."}]}], ",", " ", 
       RowBox[{
       "a", " ", "random", " ", "number", " ", "between", " ", "0", " ", 
        "and", " ", "\[Pi]", " ", "will", " ", "be", " ", "added", " ", "to", 
        " ", "both", " ", "joint", " ", "angles"}]}], " ", "*)"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
